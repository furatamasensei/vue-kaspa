{
  "name": "vkas",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/vkas.es.js",
      "require": "./dist/vkas.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./nuxt": {
      "import": "./dist/nuxt.mjs",
      "types": "./dist/nuxt.d.ts"
    }
  },
  "main": "./dist/vkas.umd.cjs",
  "module": "./dist/vkas.es.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "vite build && vite build --config vite.nuxt.config.ts",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0",
    "kaspa-wasm": ">=1.1.0",
    "vue": ">=3.4.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "dependencies": {
    "@vue/devtools-api": "^8.1.1"
  },
  "devDependencies": {
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.8.9",
    "kaspa-wasm": "workspace:*",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2",
    "vue": "^3.5.31",
    "vue-tsc": "^2.2.8"
  }
}